<Page x:Class="CleanArchGenerator.Wizard.Pages.FrameworkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Framework">
  <StackPanel Margin="20">
    <TextBlock Text="NuGet Source" />
    <TextBox x:Name="SourceBox" Width="300" />
    <TextBlock Text="Package Id" Margin="0,10,0,0" />
    <TextBox x:Name="PackageBox" Width="300" />
    <TextBlock Text="Version" Margin="0,10,0,0" />
    <TextBox x:Name="VersionBox" Width="150" />
    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
      <Button Content="Back" Width="80" Click="Back_Click"/>
      <Button Content="Next" Width="80" Margin="10,0,0,0" Click="Next_Click"/>
    </StackPanel>
  </StackPanel>
</Page>
