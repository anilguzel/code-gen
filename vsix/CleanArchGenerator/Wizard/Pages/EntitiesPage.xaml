<Page x:Class="CleanArchGenerator.Wizard.Pages.EntitiesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Entities">
  <StackPanel Margin="20">
    <TextBlock Text="Entity Name" />
    <TextBox x:Name="EntityNameBox" Width="200" />
    <Button Content="Add Entity" Width="100" Margin="0,10,0,0" Click="Add_Click"/>
    <ListBox x:Name="EntityList" Height="120" Margin="0,10,0,0" />
    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
      <Button Content="Back" Width="80" Click="Back_Click"/>
      <Button Content="Next" Width="80" Margin="10,0,0,0" Click="Next_Click"/>
    </StackPanel>
  </StackPanel>
</Page>
