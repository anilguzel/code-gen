<Page x:Class="CleanArchGenerator.Wizard.Pages.DatabasePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Database">
  <StackPanel Margin="20">
    <TextBlock Text="Provider" />
    <ComboBox x:Name="ProviderCombo" Width="200">
      <ComboBoxItem>PostgreSQL</ComboBoxItem>
      <ComboBoxItem>SQL Server</ComboBoxItem>
      <ComboBoxItem>Oracle</ComboBoxItem>
    </ComboBox>
    <TextBlock Text="Connection String" Margin="0,10,0,0" />
    <TextBox x:Name="ConnectionStringBox" Width="400" />
    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
      <Button Content="Back" Width="80" Click="Back_Click"/>
      <Button Content="Next" Width="80" Margin="10,0,0,0" Click="Next_Click"/>
    </StackPanel>
  </StackPanel>
</Page>
