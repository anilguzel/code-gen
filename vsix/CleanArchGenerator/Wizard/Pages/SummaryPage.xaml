<Page x:Class="CleanArchGenerator.Wizard.Pages.SummaryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Summary">
  <StackPanel Margin="20">
    <TextBlock Text="Ready to generate solution." />
    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
      <Button Content="Back" Width="80" Click="Back_Click"/>
      <Button Content="Generate" Width="100" Margin="10,0,0,0" Click="Generate_Click"/>
    </StackPanel>
    <TextBlock x:Name="StatusText" Margin="0,20,0,0" />
  </StackPanel>
</Page>
